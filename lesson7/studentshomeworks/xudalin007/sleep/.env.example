# 助眠故事 / 冥想 AI 朗读
# 使用 Microsoft Edge TTS（免费 · 零凭证 · 中文神经语音）
# 只需确保系统已安装 Python + edge-tts 库：
#   pip3 install edge-tts
#
# 或使用阿里云百炼 DashScope CosyVoice（默认引擎）：
#   ALIYUN_DASHSCOPE_API_KEY=你的密钥

# ---- 账户体系（注册 / 登录 / 管理员）----
# 这些功能需要服务端模式（默认 npm run dev / next start）。
# 注意：STATIC_EXPORT=1 静态导出会移除 API 路由，账户功能不可用。

# 会话签名密钥。生产环境必须设置为一个长随机字符串；
# 未设置时回退到不安全的开发默认值并打印警告。
AUTH_SECRET=

# 可选：指定某邮箱注册时自动成为管理员（否则首个注册用户即管理员）。
SEED_ADMIN_EMAIL=

# ---- 密码找回邮件（可选）----
# 全部配置后会通过 SMTP 发送重置链接；
# 未配置时仅把重置链接打印到服务端控制台；
# /api/auth/forgot 不会把重置链接返回给浏览器，避免知道邮箱即可重置。
# QQ 邮箱示例：SMTP_HOST=smtp.qq.com, SMTP_PORT=465, SMTP_USER=你的QQ邮箱,
# SMTP_PASS=QQ邮箱「授权码」而不是登录密码, SMTP_FROM=你的QQ邮箱。
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=
SMTP_REQUIRE_TLS=
