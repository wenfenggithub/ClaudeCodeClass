# 服务监听配置（可选，未设置时默认 127.0.0.1:3002）
# PORT=3002
# HOST=127.0.0.1

# 应用对外访问地址，用于生成密码重置邮件中的链接
# 默认与 HOST/PORT 拼接为 http://127.0.0.1:3002
# APP_BASE_URL=http://127.0.0.1:3002

# SMTP 凭据。未设置时密码重置邮件不会真发，
# 服务器控制台会打印重置链接，方便本地调试。
# 示例（QQ 邮箱）：
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=your-mail@qq.com
# SMTP_PASS=your-smtp-authorization-code
# SMTP_FROM=your-mail@qq.com
# SMTP_SECURE=true
